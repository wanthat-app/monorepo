# Wanthat SPA config — LOCAL DEV ONLY fallback.
#
# On the DEPLOYED site the SPA reads these from `/config.json` (written into the S3 bucket by the
# EdgeStack), so no build-time injection is needed. These VITE_* vars are only the fallback used when
# `/config.json` is absent — i.e. `pnpm --filter @wanthat/web dev` on localhost.
#
# To exercise auth locally against a deployed environment: `cp .env.example .env.local` and point each
# var at that environment's outputs (CDK stack outputs / Cognito console), then run the dev server.

# app-api HTTP API base URL (identity + links + wallet: /auth, /me).
VITE_API_URL=

# admin-api HTTP API base URL (admin surface).
VITE_ADMIN_API_URL=

# Cognito Managed Login (hosted UI) base URL — used for the discoverable passkey OAuth redirect.
VITE_MANAGED_LOGIN_URL=

# Cognito User Pool app client id (public SPA client; used as OAuth client_id).
VITE_USER_POOL_CLIENT_ID=

# Employee pool Managed Login (hosted UI) base URL — the admin console's OAuth redirect target
# (email + password + TOTP). CDK output `AdminLoginBaseUrl`.
VITE_ADMIN_MANAGED_LOGIN_URL=

# Employee pool admin SPA app client id (used as OAuth client_id for /admin login).
# CDK output `AdminSpaClientIdOut`.
VITE_ADMIN_POOL_CLIENT_ID=
