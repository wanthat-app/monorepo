{
  "projectId": "1d524ace-f23f-48f0-aa21-debd4c2041b1",
  "shape": "storybook",
  "pkg": "@wanthat/web",
  "globalName": "Wanthat",
  "srcDir": "src/ui",
  "entry": "apps/web/src/ui/index.ts",
  "tsconfig": "tsconfig.json",
  "storybookConfigDir": "apps/web/.storybook",
  "storybookStatic": ".design-sync/sb-reference",
  "buildCmd": "pnpm --filter @wanthat/web exec tailwindcss -c ../../.design-sync/tailwind.ds.config.js -i src/index.css -o dist/ds-tailwind.css && pnpm --filter @wanthat/web exec tsc -p tsconfig.json --declaration --emitDeclarationOnly --noEmit false --outDir dist/types && npx storybook build -c apps/web/.storybook -o .design-sync/sb-reference",
  "cssEntry": "dist/ds-tailwind.css",
  "guidelinesGlob": ["../../design/design_handoff_wanthat_app/README.md"],
  "readmeHeader": ".design-sync/conventions.md",
  "overrides": {
    "ConfigRow": { "cardMode": "column" },
    "SaveBar": { "cardMode": "column" },
    "BackButton": { "cardMode": "column" },
    "Card": { "cardMode": "column" },
    "Checkbox": { "cardMode": "column" },
    "OtpInput": { "cardMode": "column" },
    "RangeSlider": { "cardMode": "column" },
    "Switch": { "cardMode": "column" },
    "TextField": { "cardMode": "column" },
    "ActivityRow": { "cardMode": "column" },
    "AttributionChip": { "cardMode": "column" },
    "BalanceCard": { "cardMode": "column" },
    "MethodRow": { "cardMode": "column" },
    "PillTabs": { "cardMode": "column" },
    "PromptCard": { "cardMode": "column" },
    "RecommendationQuote": { "cardMode": "column" },
    "ShareLinkRow": { "cardMode": "column" },
    "TabBar": { "cardMode": "column" },
    "Screen": { "cardMode": "single", "viewport": "520x760" },
    "TopNav": { "cardMode": "column" },
    "Sidebar": { "cardMode": "single", "viewport": "300x620" },
    "ApprovalRow": { "cardMode": "column" },
    "Skeleton": { "cardMode": "column" },
    "FeatureRow": { "cardMode": "column" },
    "InviteCard": { "cardMode": "column" },
    "ProductCard": { "cardMode": "column" },
    "SettingsRow": { "cardMode": "column" },
    "MethodToggleRow": { "cardMode": "column" },
    "StackedStatusBar": { "cardMode": "column" }
  }
}
