{
  "name": "wanthat",
  "private": true,
  "version": "0.0.0",
  "packageManager": "pnpm@9.15.9",
  "engines": {
    "node": "24.x"
  },
  "scripts": {
    "build": "turbo run build",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "lint": "biome ci .",
    "format": "biome format --write .",
    "synth": "turbo run synth --filter=@wanthat/infra",
    "diff": "turbo run diff --filter=@wanthat/infra",
    "deploy": "turbo run deploy --filter=@wanthat/infra"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.0.0",
    "@types/node": "^24.0.0",
    "tsx": "^4.19.0",
    "turbo": "^2.0.0",
    "typescript": "^5.5.0",
    "vitest": "^3.2.6"
  }
}
